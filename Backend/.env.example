# Server
PORT=8000
CLIENT_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=1d

# Database (file path for the SQLite database)
DB_PATH=./worksync.db

# --- Gemini (FREE tier) ---
# Get a free API key at https://aistudio.google.com/apikey
# The Gemini API free tier does not require a credit card.
GEMINI_API_KEY=
# Free-tier friendly model. gemini-2.5-flash-lite / gemini-2.5-flash both work on the free tier.
GEMINI_MODEL=gemini-2.5-flash
